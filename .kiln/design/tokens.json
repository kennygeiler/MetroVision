{
  "color": {
    "primitive": {
      "neutral": {
        "50":  { "$type": "color", "$value": "oklch(0.980 0.003 260)", "$description": "Lightest — cool silver" },
        "100": { "$type": "color", "$value": "oklch(0.940 0.005 260)", "$description": "Very light" },
        "200": { "$type": "color", "$value": "oklch(0.880 0.008 260)", "$description": "Soft silver" },
        "300": { "$type": "color", "$value": "oklch(0.780 0.010 260)", "$description": "Light mid" },
        "400": { "$type": "color", "$value": "oklch(0.650 0.012 260)", "$description": "Mid — secondary text" },
        "500": { "$type": "color", "$value": "oklch(0.500 0.014 260)", "$description": "Base — muted text" },
        "600": { "$type": "color", "$value": "oklch(0.400 0.016 260)", "$description": "Dark — strong border" },
        "700": { "$type": "color", "$value": "oklch(0.300 0.016 260)", "$description": "Darker — default border" },
        "800": { "$type": "color", "$value": "oklch(0.220 0.014 260)", "$description": "Deep — elevated surface" },
        "900": { "$type": "color", "$value": "oklch(0.160 0.012 260)", "$description": "Near-black — card surface" },
        "950": { "$type": "color", "$value": "oklch(0.110 0.010 260)", "$description": "Deepest — primary surface" }
      },
      "accent": {
        "light":  { "$type": "color", "$value": "oklch(0.780 0.140 280)", "$description": "Light violet accent" },
        "base":   { "$type": "color", "$value": "oklch(0.620 0.200 280)", "$description": "Primary violet — cinematic precision" },
        "strong": { "$type": "color", "$value": "oklch(0.480 0.220 280)", "$description": "Deep violet" }
      },
      "signal": {
        "warm":   { "$type": "color", "$value": "oklch(0.700 0.160 55)", "$description": "Warm amber — for annotations, highlights" },
        "cool":   { "$type": "color", "$value": "oklch(0.700 0.140 210)", "$description": "Cool cyan — for data, metadata" },
        "danger": { "$type": "color", "$value": "oklch(0.600 0.200 25)", "$description": "Red — errors, destructive" },
        "success":{ "$type": "color", "$value": "oklch(0.650 0.160 145)", "$description": "Green — confirmations" }
      }
    },
    "semantic": {
      "surface": {
        "primary":   { "$type": "color", "$value": "{color.primitive.neutral.950}", "$description": "Main background — near-black with cool undertone" },
        "secondary": { "$type": "color", "$value": "{color.primitive.neutral.900}", "$description": "Card/panel background" },
        "tertiary":  { "$type": "color", "$value": "{color.primitive.neutral.800}", "$description": "Elevated surface — modals, popovers" },
        "inverse":   { "$type": "color", "$value": "{color.primitive.neutral.50}", "$description": "Light mode surface (reserved)" }
      },
      "text": {
        "primary":   { "$type": "color", "$value": "{color.primitive.neutral.50}", "$description": "Primary text — near-white" },
        "secondary": { "$type": "color", "$value": "{color.primitive.neutral.400}", "$description": "Secondary text — metadata, labels" },
        "tertiary":  { "$type": "color", "$value": "{color.primitive.neutral.500}", "$description": "Muted text — timestamps, captions" },
        "accent":    { "$type": "color", "$value": "{color.primitive.accent.base}", "$description": "Accent text — links, highlights" }
      },
      "border": {
        "subtle":  { "$type": "color", "$value": "{color.primitive.neutral.800}", "$description": "Subtle divider" },
        "default": { "$type": "color", "$value": "{color.primitive.neutral.700}", "$description": "Standard border" },
        "strong":  { "$type": "color", "$value": "{color.primitive.neutral.600}", "$description": "Emphasized border" }
      },
      "interactive": {
        "default": { "$type": "color", "$value": "{color.primitive.accent.base}", "$description": "Button/link default" },
        "hover":   { "$type": "color", "$value": "{color.primitive.accent.light}", "$description": "Hover state" },
        "active":  { "$type": "color", "$value": "{color.primitive.accent.strong}", "$description": "Active/pressed" }
      },
      "overlay": {
        "annotation": { "$type": "color", "$value": "{color.primitive.signal.warm}", "$description": "Video overlay annotations — warm amber" },
        "data":       { "$type": "color", "$value": "{color.primitive.signal.cool}", "$description": "Video overlay data readouts — cool cyan" }
      }
    }
  },
  "font": {
    "family": {
      "heading": { "$type": "fontFamily", "$value": "var(--font-heading, system-ui)", "$description": "Heading typeface — geometric sans-serif recommended (e.g., Geist, DM Sans)" },
      "body":    { "$type": "fontFamily", "$value": "var(--font-body, system-ui)", "$description": "Body typeface — humanist sans-serif recommended (e.g., Inter, DM Sans)" },
      "mono":    { "$type": "fontFamily", "$value": "var(--font-mono, ui-monospace, monospace)", "$description": "Code/data typeface — monospaced for metadata readouts" }
    },
    "size": {
      "xs":   { "$type": "dimension", "$value": "0.75rem",  "$description": "12px — captions, timestamps" },
      "sm":   { "$type": "dimension", "$value": "0.875rem", "$description": "14px — metadata labels, small UI text" },
      "base": { "$type": "dimension", "$value": "1rem",     "$description": "16px — body text" },
      "lg":   { "$type": "dimension", "$value": "1.125rem", "$description": "18px — large body" },
      "xl":   { "$type": "dimension", "$value": "1.25rem",  "$description": "20px — subheading" },
      "2xl":  { "$type": "dimension", "$value": "1.5rem",   "$description": "24px — section heading" },
      "3xl":  { "$type": "dimension", "$value": "2rem",     "$description": "32px — page heading" },
      "4xl":  { "$type": "dimension", "$value": "2.5rem",   "$description": "40px — display" },
      "5xl":  { "$type": "dimension", "$value": "3.5rem",   "$description": "56px — hero" }
    },
    "weight": {
      "normal": { "$type": "fontWeight", "$value": "400", "$description": "Body weight" },
      "medium": { "$type": "fontWeight", "$value": "500", "$description": "Emphasis, labels" },
      "semibold": { "$type": "fontWeight", "$value": "600", "$description": "Subheadings" },
      "bold":   { "$type": "fontWeight", "$value": "700", "$description": "Headings, hero text" }
    },
    "letterSpacing": {
      "tight":   { "$type": "dimension", "$value": "-0.04em", "$description": "Display/hero text — cinematic density" },
      "snug":    { "$type": "dimension", "$value": "-0.02em", "$description": "Headings" },
      "normal":  { "$type": "dimension", "$value": "0em",     "$description": "Body text" },
      "wide":    { "$type": "dimension", "$value": "0.08em",  "$description": "All-caps labels — technical precision feel" }
    }
  },
  "space": {
    "1":  { "$type": "dimension", "$value": "4px",   "$description": "Tight — inline spacing" },
    "2":  { "$type": "dimension", "$value": "8px",   "$description": "Compact — icon gaps" },
    "3":  { "$type": "dimension", "$value": "12px",  "$description": "Snug — form elements" },
    "4":  { "$type": "dimension", "$value": "16px",  "$description": "Base — card padding" },
    "5":  { "$type": "dimension", "$value": "20px",  "$description": "Comfortable" },
    "6":  { "$type": "dimension", "$value": "24px",  "$description": "Relaxed — section padding" },
    "8":  { "$type": "dimension", "$value": "32px",  "$description": "Spacious — between cards" },
    "10": { "$type": "dimension", "$value": "40px",  "$description": "Airy" },
    "12": { "$type": "dimension", "$value": "48px",  "$description": "Wide — section gaps" },
    "16": { "$type": "dimension", "$value": "64px",  "$description": "Expansive" },
    "20": { "$type": "dimension", "$value": "80px",  "$description": "Section gap" },
    "24": { "$type": "dimension", "$value": "96px",  "$description": "Major section" },
    "32": { "$type": "dimension", "$value": "128px", "$description": "Hero section" }
  }
}
